{
  "name": "jinzhu-desktop-overlay",
  "version": "1.2.0",
  "description": "Independent Windows desktop pet overlay for Jinzhu",
  "main": "main.js",
  "scripts": { "start": "electron .", "dev": "electron .", "dist": "electron-builder --win portable" },
  "build": {
    "appId": "com.kimyjxyim.jinzhu.overlay",
    "productName": "Jinzhu Desktop Pet",
    "asar": true,
    "files": ["**/*", "!dist/**"],
    "extraResources": [{ "from": "../assets", "to": "assets" }],
    "directories": { "output": "dist" },
    "win": { "target": [{ "target": "portable", "arch": ["x64"] }], "signAndEditExecutable": false, "artifactName": "Jinzhu-Desktop-Pet-${version}-portable.exe" }
  },
  "devDependencies": { "electron": "^31.0.0", "electron-builder": "^24.13.3" }
}
